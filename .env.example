# Database
POSTGRES_DB=flighttracker
POSTGRES_USER=flighttracker
POSTGRES_PASSWORD=changeme

# App secret (generate with: openssl rand -hex 32)
SECRET_KEY=changeme-super-secret-key-32chars-minimum

# Admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Port to expose (default 8080)
PORT=8080

# Set this if you're behind a reverse proxy at a specific path
# VITE_API_URL=https://flights.yourdomain.com
